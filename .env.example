PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/littop
JWT_SECRET=change-me
PUBLIC_BASE_URL=http://localhost:4000

# VK social auth
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_SCOPE=email
VK_API_VERSION=5.199
